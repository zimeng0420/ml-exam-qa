---
import Layout from "../components/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TumLogo from "../components/TumLogo.astro";
import GlobalSearch from "../components/islands/GlobalSearch.vue";
import { getOrderedChapters, chapterStats, buildSearchIndex } from "../lib/content";
import { manifest } from "../lib/manifest";
import { EXAM_NAMES, examOf } from "../lib/exams";
import { url } from "../lib/paths";
import updates from "../../data/updates.json";

const chapters = await getOrderedChapters();
const index = await buildSearchIndex();

let totalQ = 0;
let totalTopics = 0;
const statsById = new Map<string, ReturnType<typeof chapterStats>>();
for (const ch of chapters) {
  const s = chapterStats(ch);
  statsById.set(ch.data.id, s);
  totalQ += s.questions;
  totalTopics += s.topics;
}

// chapter cards in manifest order (ready + coming-soon)
const cards = manifest.chapters.map((m) => {
  const ready = m.status === "ready";
  const s = ready ? statsById.get(m.id) : undefined;
  return { ...m, ready, stats: s };
});

// exam question counts: each question once per exam it appears in
const examCounts = new Map<string, number>();
for (const e of index) {
  const seen = new Set<string>();
  for (const s of e.srcs) {
    const x = examOf(s);
    if (x && !seen.has(x)) {
      seen.add(x);
      examCounts.set(x, (examCounts.get(x) ?? 0) + 1);
    }
  }
}
const examCards = manifest.exams
  .filter((e) => examCounts.get(e))
  .map((e) => ({ code: e, name: EXAM_NAMES[e] ?? e, n: examCounts.get(e) ?? 0 }));

// popular concept tags
const tagCounts = new Map<string, number>();
for (const e of index) for (const t of e.tg) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const popTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([t, n]) => ({ t, n }));

const recentUpdates = (updates as { date: string; text: string }[]).slice(0, 3);
// UTM tags so friend-shared visits show up in GA4 as source/medium
// "share / referral" (campaign "friend"), instead of blending into Direct.
const shareText =
  "Hey! Just found a Machine Learning exam-prep deck: https://YOUR-USERNAME.github.io/ml-exam-qa/?utm_source=share&utm_medium=referral&utm_campaign=friend";
---

<Layout title="ML Exam Q&A">
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-top">
        <TumLogo />
        <span class="kicker">Machine Learning · 950883155 (S26)</span>
      </div>
      <h1>Machine Learning</h1>
      <ul class="hero-points">
        <li>
          <div class="hp-head"><span class="hp-ic">🔎</span><span class="hp-t">Search by concept</span></div>
          <span class="hp-d">Follow one idea across every chapter.</span>
        </li>
        <li>
          <div class="hp-head"><span class="hp-ic">✅</span><span class="hp-t">Interactive quizzes</span></div>
          <span class="hp-d">Pick. Check. Then see why.</span>
        </li>
        <li>
          <div class="hp-head"><span class="hp-ic">🤖</span><span class="hp-t">AI practice</span></div>
          <span class="hp-d">Fresh questions for every concept.</span>
        </li>
      </ul>
      <div class="hero-cta">
        <p class="hero-cta-text">
          <b>Free course revision deck.</b> Built to help you master the Machine Learning exam. If it helps — pass it on.
        </p>
        <div class="hero-cta-pills">
          <button class="share-pill" type="button" data-share={shareText}>
            <span class="share-ic" aria-hidden="true">🔗</span><span class="share-txt">Share with a friend</span>
          </button>
          <a class="share-pill kb-pill" href={url("/knowledge")}>
            <span class="share-ic" aria-hidden="true">🧠</span><span>Knowledge Base</span>
          </a>
          <a class="share-pill" href={url("/review")}>
            <span class="share-ic" aria-hidden="true">📈</span><span>Review &amp; flashcards</span>
          </a>
          <a class="share-pill" href="https://github.com/YOUR-USERNAME/ml-exam-qa" target="_blank" rel="noopener">
            <span class="share-ic" aria-hidden="true">⭐</span><span>Source project</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <main class="hub">
    <GlobalSearch client:load totalQ={totalQ} />

    <section class="poptags">
      <div class="poptags-head">
        <span class="poptags-label">Popular tags</span>
        <a class="poptags-all" href={url("/tags")}>All {tagCounts.size} tags →</a>
      </div>
      <div class="poptags-row">
        {
          popTags.map(({ t, n }) => (
            <a class="ptag" href={`${url("/tags")}?t=${encodeURIComponent(t)}`}>
              {t}
              <span class="ptag-n">{n}</span>
            </a>
          ))
        }
      </div>
    </section>

    <details class="progress-card" id="progress" hidden open>
      <summary class="prog-head">
        <span class="prog-title">Your progress</span>
        <span id="authctl" class="authctl"></span>
      </summary>
      <div id="prog-body"></div>
    </details>

    <div class="view-toggle" role="tablist" aria-label="Browse by">
      <button type="button" class="vt-btn active" data-view="chapters" aria-selected="true">By chapter</button>
      <button type="button" class="vt-btn" data-view="exams" aria-selected="false">By exam</button>
    </div>

    <div class="cards" id="view-chapters">
      {
        cards.map((c) =>
          c.ready ? (
            <a class="card" href={url(`/chapters/${c.id}`)}>
              <div class="card-top">
                <span class="card-roman">{c.roman}</span>
                <span class="card-prog" data-ch={c.id}></span>
              </div>
              <h3>{c.title}</h3>
              <div class="card-meta">
                {c.stats!.questions} questions · {c.stats!.topics} topics
              </div>
            </a>
          ) : (
            <div class="card card-soon">
              <div class="card-roman">{c.roman}</div>
              <h3>{c.title}</h3>
              <div class="card-meta">coming soon</div>
            </div>
          ),
        )
      }
    </div>

    <div class="examgrid" id="view-exams" hidden>
      {
        examCards.map((e) => (
          <a class="examcard" href={`${url("/exams")}?e=${encodeURIComponent(e.code)}`}>
            <span class="examcard-top">
              <span class="examcard-code">{e.code}</span>
              <span class="card-prog" data-exam={e.code}></span>
            </span>
            <span class="examcard-name">{e.name}</span>
            <span class="examcard-n">{e.n} questions</span>
          </a>
        ))
      }
    </div>

    {
      recentUpdates.length > 0 && (
        <details class="updates collapsible" open>
          <summary class="collapse-head"><span>📣 Recent updates</span></summary>
          <ul class="up-list">
            {recentUpdates.map((u) => (
              <li>
                <span class="up-date">{u.date}</span>
                <span class="up-text">{u.text}</span>
              </li>
            ))}
          </ul>
        </details>
      )
    }

    <details class="how collapsible" open>
      <summary class="collapse-head"><span>🧭 How to use this deck</span></summary>
      <div class="how-grid">
        <div class="how-col">
          <h3>🔎 Find</h3>
          <ul>
            <li>Search any keyword or concept <b>tag</b> (e.g. <i>attention</i>, <i>GRPO</i>).</li>
            <li>Jump to an exact question by code — type <span class="src">WS26 P6.1</span>.</li>
            <li>Browse <b>by exam</b> (tap a paper above) or <b>by tag</b> across all chapters.</li>
          </ul>
        </div>
        <div class="how-col">
          <h3>📝 Practice</h3>
          <ul>
            <li>Toggle <b>Review / Test</b> (top-right): Review shows answers, Test hides them.</li>
            <li><b>Interactive</b> multiple-choice, short-answer (matching words light up green) &amp; number-checked calculation questions.</li>
            <li>Answers follow the <b>official solutions</b>; <span class="src-ai">AI-generated</span> items are marked.</li>
          </ul>
        </div>
        <div class="how-col">
          <h3>📈 Track</h3>
          <ul>
            <li><b>🃏 Flashcards</b> — study a due / wrong-book / all deck and rate each card <i>Again / Hard / Good / Easy</i> (spaced repetition).</li>
            <li>Mark <b>Reviewed</b>, keep a <b>wrong book</b>, or jot a <b>note</b> (<b>Markdown + math</b>).</li>
            <li>The <b>Review page</b> groups what's due by chapter; <b>sign in</b> to sync ML progress across devices.</li>
          </ul>
        </div>
      </div>
    </details>

    <section class="feedback" id="feedback">
      <div class="feedback-text">
        <span class="feedback-title">💬 Feedback &amp; issues</span>
        <span class="feedback-sub">Spotted a wrong answer or have a suggestion? It goes straight to the author.</span>
      </div>
      <div class="feedback-actions">
        <a class="feedback-link" id="feedback-link" target="_blank" rel="noopener">Open the feedback form →</a>
        <a class="feedback-issue" href="https://github.com/YOUR-USERNAME/ml-exam-qa/issues" target="_blank" rel="noopener">Open an issue →</a>
      </div>
    </section>

    <p class="hubnote">
      All 11 ML syllabus chapters complete — {totalQ} questions across {totalTopics} knowledge points,
      mapped from SS24, SS25, WS26 and the W1-W11 lecture plan.
    </p>
  </main>

  <SiteFooter />
</Layout>
